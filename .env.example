# ─── Ollama Cloud ──────────────────────────────────────────────
# KodaAI talks to Ollama Cloud (NOT a local Ollama instance).
# Get an API key at https://ollama.com  →  Settings → Keys
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_DEFAULT_MODEL=gemma4:31b

# ─── Web search ────────────────────────────────────────────────
# Primary backend is the Ollama Cloud Web Search API, which reuses
# OLLAMA_API_KEY above — no separate search key or server required.
#
# SearXNG (below) is only used as a fallback, e.g. when OLLAMA_BASE_URL
# points at a local Ollama daemon that has no web search.
SEARXNG_BASE_URL=http://localhost:8080

# Optional: Brave Search fallback (used only if the above are unavailable)
BRAVE_SEARCH_API_KEY=

# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=KodaAI
NEXT_PUBLIC_APP_VERSION=1.0.0
